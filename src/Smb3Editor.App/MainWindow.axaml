<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Smb3Editor.App"
        x:Class="Smb3Editor.App.MainWindow"
        Title="Warp Whistle"
        Width="1440"
        Height="900"
        MinWidth="900"
        MinHeight="620">
  <Window.Styles>
    <Style Selector="Button#SafetyBanner:pointerover">
      <Setter Property="Background" Value="#A92B1E" />
    </Style>
    <Style Selector="Button#SafetyBanner:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#A92B1E" />
    </Style>
    <Style Selector="Button#FixUnsafeButton:pointerover">
      <Setter Property="Background" Value="#8A5A12" />
    </Style>
    <Style Selector="Button#FixUnsafeButton:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#8A5A12" />
    </Style>
  </Window.Styles>
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
    <Border Grid.Row="0" Background="#172231" Padding="6,2">
      <StackPanel Orientation="Horizontal" Spacing="4">
      <Menu>
        <MenuItem Header="File">
          <MenuItem Header="Open ROM" Click="OpenRom_Click" />
          <MenuItem Header="Open Project" Click="OpenProject_Click" />
          <MenuItem Header="Save Project" Click="SaveProject_Click" />
          <MenuItem Header="Open Workspace Folder" Click="OpenWorkspace_Click" />
          <MenuItem x:Name="OpenTraceLogsMenuItem" Header="Open Trace Logs" Click="OpenTraceLogs_Click" />
          <MenuItem Header="Open Legacy Preview Cache" Click="OpenLegacyPreviewCache_Click" />
          <Separator />
          <MenuItem Header="Export ROM" Click="ExportRom_Click" />
          <MenuItem Header="Export BPS" Click="ExportBps_Click" />
        </MenuItem>
        <MenuItem Header="Edit">
          <MenuItem Header="Undo" Click="Undo_Click" />
          <MenuItem Header="Redo" Click="Redo_Click" />
          <Separator />
          <MenuItem Header="Copy" Click="Copy_Click" />
          <MenuItem Header="Paste" Click="Paste_Click" />
          <MenuItem Header="Delete" Click="Delete_Click" />
        </MenuItem>
      </Menu>
      <Button Content="Patches" Click="OpenPatchManager_Click" Padding="10,3" VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Background="#111B28" BorderBrush="#31445A" BorderThickness="0,0,0,1" Padding="10,7">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
        <TextBlock Text="Level" VerticalAlignment="Center" Foreground="#9FB0C4" />
        <local:SearchableDropDown x:Name="LevelList" Width="220" SelectionChanged="LevelList_SelectionChanged" />
        <SplitButton x:Name="PlayButton" Content="Play ROM" Click="PlayButton_Click">
          <SplitButton.Flyout>
            <MenuFlyout Placement="Bottom">
              <MenuItem x:Name="PlayModeMenuItem" Header="Play Level" Click="SwitchPlayMode_Click" />
            </MenuFlyout>
          </SplitButton.Flyout>
        </SplitButton>
        <ToggleButton x:Name="TracePlayLevelToggle" Content="Trace" ToolTip.Tip="Launch the selected play mode with its bundled Mesen trace" />
        <ToggleButton x:Name="GridToggle" Content="Grid" IsChecked="True" Click="GridToggle_Click" />
        <Button Content="Clear level" Click="ClearLevel_Click" />
        <Button x:Name="UndoButton" Content="↶" Width="32" Click="Undo_Click" ToolTip.Tip="Undo (Ctrl+Z)" />
        <Button x:Name="RedoButton" Content="↷" Width="32" Click="Redo_Click" ToolTip.Tip="Redo (Ctrl+Y)" />
        <Button x:Name="SaveButton" Content="💾" Width="34" Click="SaveProject_Click" ToolTip.Tip="Save project (Ctrl+S)" />
        <TextBlock x:Name="SaveStateText" Text="Saved" VerticalAlignment="Center" Foreground="#8FA0B5" FontSize="12" />
        <TextBlock Text="Ctrl + wheel: zoom" VerticalAlignment="Center" Foreground="#718399" Margin="8,0,0,0" />
        <!-- This fixed slot keeps feedback in the app chrome without moving the canvas. -->
        <Border Width="360" Height="30" VerticalAlignment="Center" Margin="8,0,0,0">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <Button x:Name="DesignerNotice" IsVisible="False" Height="28" Padding="8,3"
                    Background="#443814" BorderBrush="#A98732" BorderThickness="1"
                    Click="DesignerNotice_Click" ToolTip.Tip="Open Diagnostics">
              <TextBlock x:Name="DesignerNoticeText" Width="250" FontSize="12" FontWeight="SemiBold"
                         Foreground="White" TextTrimming="CharacterEllipsis" />
            </Button>
            <Button x:Name="SafetyBanner" IsVisible="False" Height="28" Padding="8,3"
                    Background="#7F261D" BorderBrush="#D98579" BorderThickness="1"
                    Click="SafetyBanner_Click" ToolTip.Tip="Open Diagnostics">
              <TextBlock x:Name="SafetyBannerText" Width="235" FontSize="12" FontWeight="SemiBold"
                         Foreground="White" TextTrimming="CharacterEllipsis" />
            </Button>
            <Button x:Name="FixUnsafeButton" IsVisible="False" Content="Fix" Height="28"
                    Padding="8,3" Background="#6C4A13" BorderBrush="#C9993E" BorderThickness="1"
                    ToolTip.Tip="Fix ordering" Click="FixUnsafe_Click" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <SplitView Grid.Row="2"
               x:Name="WorkspaceSplitView"
               DisplayMode="Inline"
               PanePlacement="Right"
               OpenPaneLength="360"
               CompactPaneLength="0"
               IsPaneOpen="True">
      <SplitView.Pane>
        <TabControl x:Name="SidebarTabs" SelectedIndex="0" Background="#111923" BorderBrush="#31445A" BorderThickness="1,0,0,0">
          <TabItem Header="Properties">
        <Border Background="#111923" Padding="16">
          <ScrollViewer>
            <StackPanel>
              <TextBlock Classes="section" Text="Selection" Margin="0,0,0,5" />
              <TextBlock x:Name="SelectionText" Text="Nothing selected" TextWrapping="Wrap" Margin="0,0,0,16" />
              <TextBlock Classes="section" Text="Level properties" />
              <TextBlock Text="Screens" />
              <NumericUpDown x:Name="ScreenCountBox" Minimum="1" Maximum="16" Increment="1" Margin="0,3,0,10" ValueChanged="HeaderValueChanged" />
              <TextBlock Text="Background palette" />
              <ComboBox x:Name="BackgroundPaletteBox" Margin="0,3,0,10" SelectionChanged="HeaderSelectionChanged">
                <ComboBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="{Binding Name}"/><local:PalettePreview Colors="{Binding Colors}"/></StackPanel></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="Object palette" />
              <ComboBox x:Name="ObjectPaletteBox" Margin="0,3,0,10" SelectionChanged="HeaderSelectionChanged">
                <ComboBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="{Binding Name}"/><local:PalettePreview Colors="{Binding Colors}"/></StackPanel></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
              <StackPanel IsVisible="False">
              <TextBlock Text="Palette editor" TextWrapping="Wrap" />
              <StackPanel x:Name="PaletteSwatches" Orientation="Horizontal" Margin="0,3,0,5" />
              <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,0,0,12">
                <Button Content="Apply palette" Click="ApplyPalette_Click" />
                <Button x:Name="PaletteHeartButton" Content="♡" Width="34" ToolTip.Tip="Save or remove this palette from the library" Click="TogglePaletteLibrary_Click" />
                <Button Content="Apply library" Click="ApplyPaletteLibrary_Click" />
              </StackPanel>
              </StackPanel>
              <Button Content="Open Palette Editor" Click="OpenPaletteEditor_Click" Margin="0,0,0,12" />
              <TextBlock Text="Music" />
              <ComboBox x:Name="MusicBox" Margin="0,3,0,10" SelectionChanged="HeaderSelectionChanged" />
              <TextBlock Text="Time setting" />
              <ComboBox x:Name="TimeBox" Margin="0,3,0,18" SelectionChanged="HeaderSelectionChanged" />

              <TextBlock Classes="section" Text="Space" />
              <TextBlock x:Name="SpaceText" Text="No area loaded" TextWrapping="Wrap" Margin="0,0,0,18" />

              <TextBlock Classes="section" Text="External emulator" />
              <TextBox x:Name="EmulatorPathBox" PlaceholderText="Emulator executable" Margin="0,0,0,6" />
              <Button Content="Choose emulator" Click="ChooseEmulator_Click" Margin="0,0,0,8" />
              <TextBlock Text="Arguments, one per line. Use {rom} for the temporary ROM." TextWrapping="Wrap" FontSize="12" />
              <TextBox x:Name="EmulatorArgumentsBox" AcceptsReturn="True" Height="86" Text="{}{rom}" Margin="0,5,0,0" />
            </StackPanel>
          </ScrollViewer>
        </Border>
          </TabItem>
          <TabItem Header="Items">
            <Border Background="#111923" Padding="2">
              <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="6">
                <TextBox x:Name="CatalogSearchBox" PlaceholderText="Search objects and enemies" TextChanged="CatalogFilterChanged" />
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="3">
                  <ToggleButton x:Name="CatalogAllFilter" Tag="0" Content="All" IsChecked="True" Padding="7,2" Click="CatalogFilterTab_Click" />
                  <ToggleButton x:Name="CatalogObjectsFilter" Tag="1" Content="Objects" Padding="7,2" Click="CatalogFilterTab_Click" />
                  <ToggleButton x:Name="CatalogEnemiesFilter" Tag="2" Content="Sprites" Padding="7,2" Click="CatalogFilterTab_Click" />
                  <ToggleButton x:Name="CatalogRecentFilter" Tag="3" Content="Recent" Padding="7,2" Click="CatalogFilterTab_Click" />
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                  <ToggleButton x:Name="CatalogGridToggle" Content="Grid" IsChecked="True" Click="CatalogViewChanged" />
                  <ToggleButton x:Name="CatalogListToggle" Content="List" Click="CatalogViewChanged" />
                  <TextBlock Text="Tile size" VerticalAlignment="Center" Margin="8,0,0,0" />
                  <Slider x:Name="CatalogTileSizeSlider" Minimum="52" Maximum="112" Value="72" Width="82" />
                </StackPanel>
                <ScrollViewer Grid.Row="3">
                  <Grid>
                    <ListBox x:Name="CatalogGrid" SelectionChanged="CatalogSelectionChanged">
                      <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                      <ListBox.Styles>
                        <Style Selector="ListBoxItem"><Setter Property="Padding" Value="2" /><Setter Property="Margin" Value="0" /><Setter Property="MinWidth" Value="0" /><Setter Property="BorderThickness" Value="0" /><Setter Property="Background" Value="Transparent" /></Style>
                        <Style Selector="ListBoxItem:selected"><Setter Property="Background" Value="#3478A5" /></Style>
                      </ListBox.Styles>
                      <ListBox.ItemTemplate><DataTemplate>
                        <Border Classes="catalog-tile" Width="{Binding Value, ElementName=CatalogTileSizeSlider}" Height="{Binding Value, ElementName=CatalogTileSizeSlider}" Margin="0" Padding="0" Background="#182534" BorderBrush="#3A506B" BorderThickness="1" ToolTip.Tip="{Binding Display}">
                          <Grid>
                            <local:CatalogPreview Preview="{Binding Preview}" />
                            <TextBlock Text="{Binding ShortName}" IsVisible="{Binding HasNoPreview}" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Margin="4" FontSize="11" />
                          </Grid>
                        </Border>
                      </DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                    <ListBox x:Name="CatalogListView" IsVisible="False" SelectionChanged="CatalogSelectionChanged">
                      <ListBox.ItemTemplate><DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="4"><TextBlock Text="{Binding PreviewGlyph}" Width="28" FontSize="20" Foreground="#9FD9FF"/><TextBlock Text="{Binding Display}" TextWrapping="Wrap" /></StackPanel>
                      </DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </ScrollViewer>
              </Grid>
            </Border>
          </TabItem>
          <TabItem Header="Patches">
            <Border Background="#111923" Padding="16">
              <ScrollViewer>
                <StackPanel Spacing="10">
                  <TextBlock Classes="section" Text="Enhanced patches" />
                  <TextBlock Text="Optional PRG1 changes for compatible MMC3 flash carts and repro boards. Vanilla exports remain unchanged until enabled." TextWrapping="Wrap" />
                  <StackPanel x:Name="PatchControls" Spacing="14">
                    <TextBlock x:Name="NoPatchesText" Text="No patches are included. Use the top-bar Patches button to add one." TextWrapping="Wrap" Foreground="#9FB0C4" />
                    <TextBlock x:Name="PatchLevelText" Text="Level overrides" Foreground="#9FB0C4" />
                    <Border x:Name="QuickRetryCard" Background="#182534" BorderBrush="#3A506B" BorderThickness="1" Padding="6" ToolTip.Tip="Normal death restarts the level without visiting the overworld.">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Quick Retry" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ComboBox x:Name="QuickRetryOverride" Grid.Column="1" Width="120" SelectionChanged="PatchOverrideChanged" />
                      </Grid>
                    </Border>
                    <Border x:Name="QuitToMapCard" Background="#182534" BorderBrush="#3A506B" BorderThickness="1" Padding="6" ToolTip.Tip="While paused, Select exits the level without completing it.">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Start + Select: Return to Map" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ComboBox x:Name="QuitToMapOverride" Grid.Column="1" Width="120" SelectionChanged="PatchOverrideChanged" />
                      </Grid>
                    </Border>
                    <Border x:Name="ContinuousAutoScrollCard" Background="#182534" BorderBrush="#3A506B" BorderThickness="1" Padding="6" ToolTip.Tip="Enhanced only: keeps horizontal auto-scroll moving until the level's stock camera boundary.">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Full-Level Auto-Scroll" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ComboBox x:Name="ContinuousAutoScrollOverride" Grid.Column="1" Width="120" SelectionChanged="PatchOverrideChanged" />
                      </Grid>
                    </Border>
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </Border>
          </TabItem>
        </TabControl>
      </SplitView.Pane>

      <Border Background="#0D141D">
        <ScrollViewer x:Name="LevelScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <ScrollViewer.Styles>
            <Style Selector="ScrollBar[Orientation=Vertical]"><Setter Property="Width" Value="10" /></Style>
            <Style Selector="ScrollBar[Orientation=Horizontal]"><Setter Property="Height" Value="10" /></Style>
          </ScrollViewer.Styles>
          <local:LevelCanvas x:Name="EditorCanvas" />
        </ScrollViewer>
      </Border>
    </SplitView>

    <Border Grid.Row="3" Background="#111B28" BorderBrush="#31445A" BorderThickness="0,1,0,0" Padding="10,6">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <TextBlock x:Name="RomStatusText" Text="No ROM loaded" TextWrapping="Wrap" Foreground="#9FB0C4" />
        <TextBlock x:Name="ByteBudgetText" Grid.Column="1" VerticalAlignment="Center" Foreground="#9FB0C4" />
      </Grid>
    </Border>

    <Expander x:Name="DiagnosticsPanel" Grid.Row="4" IsExpanded="False" Background="#101720" MaxHeight="180">
      <Expander.Header>
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="Diagnostics" />
          <TextBlock x:Name="DiagnosticsCountText" Foreground="#9FB0C4" />
        </StackPanel>
      </Expander.Header>
      <ListBox x:Name="DiagnosticsList" Height="150" MaxWidth="900" HorizontalAlignment="Left" ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" TextWrapping="Wrap" MaxWidth="860" Margin="3,2" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Expander>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Smb3Editor.App"
        x:Class="Smb3Editor.App.MainWindow"
        Title="Warp Whistle"
        Width="1440"
        Height="900"
        MinWidth="900"
        MinHeight="620">
  <Window.Styles>
    <Style Selector="Button#SafetyBanner:pointerover">
      <Setter Property="Background" Value="#A92B1E" />
    </Style>
    <Style Selector="Button#SafetyBanner:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#A92B1E" />
    </Style>
    <Style Selector="Button#FixUnsafeButton:pointerover">
      <Setter Property="Background" Value="#8A5A12" />
    </Style>
    <Style Selector="Button#FixUnsafeButton:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#8A5A12" />
    </Style>
  </Window.Styles>
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
    <Border Grid.Row="0" Background="#172231" Padding="10,8">
      <StackPanel Orientation="Horizontal">
        <Button Classes="toolbar" Content="Open ROM" Click="OpenRom_Click" />
        <Button Classes="toolbar" Content="Open Project" Click="OpenProject_Click" />
        <Button Classes="toolbar" Content="Save Project" Click="SaveProject_Click" />
        <Button Classes="toolbar" Content="Export ROM" Click="ExportRom_Click" />
        <Button Classes="toolbar" Content="Export BPS" Click="ExportBps_Click" />
        <Button Classes="toolbar" Content="Play Test" Click="PlayTest_Click" />
        <Border Width="1" Background="#526174" Margin="4,2,10,2" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Background="#111B28" BorderBrush="#31445A" BorderThickness="0,0,0,1" Padding="10,7">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
        <TextBlock Text="Level" VerticalAlignment="Center" Foreground="#9FB0C4" />
        <local:SearchableDropDown x:Name="LevelList" Width="220" SelectionChanged="LevelList_SelectionChanged" />
        <Border Width="1" Height="25" Background="#526174" Margin="5,0" />
        <TextBlock Text="Add object" VerticalAlignment="Center" Foreground="#9FB0C4" />
        <local:SearchableDropDown x:Name="CatalogList" Width="285" />
        <Button Content="Add" Click="AddCatalog_Click" />
        <Border Width="1" Height="25" Background="#526174" Margin="5,0" />
        <ToggleButton x:Name="PropertiesToggle" Content="Properties" Click="PropertiesToggle_Click" />
        <ToggleButton x:Name="GridToggle" Content="Grid" IsChecked="True" Click="GridToggle_Click" />
        <TextBlock Text="Ctrl + wheel: zoom" VerticalAlignment="Center" Foreground="#718399" Margin="8,0,0,0" />
      </StackPanel>
    </Border>

    <SplitView Grid.Row="2"
               x:Name="WorkspaceSplitView"
               DisplayMode="Overlay"
               PanePlacement="Right"
               OpenPaneLength="320"
               CompactPaneLength="0"
               IsPaneOpen="False"
               PaneClosing="WorkspaceSplitView_PaneClosing" PaneClosed="WorkspaceSplitView_PaneClosed">
      <SplitView.Pane>
        <Border Background="#111923" BorderBrush="#31445A" BorderThickness="1,0,0,0" Padding="16">
          <ScrollViewer>
            <StackPanel>
              <TextBlock Classes="section" Text="Selection" Margin="0,0,0,5" />
              <TextBlock x:Name="SelectionText" Text="Nothing selected" TextWrapping="Wrap" Margin="0,0,0,16" />
              <TextBlock Classes="section" Text="Level properties" />
              <TextBlock Text="Screens" />
              <NumericUpDown x:Name="ScreenCountBox" Minimum="1" Maximum="16" Increment="1" Margin="0,3,0,10" ValueChanged="HeaderValueChanged" />
              <TextBlock Text="Background palette" />
              <ComboBox x:Name="BackgroundPaletteBox" Margin="0,3,0,10" SelectionChanged="HeaderSelectionChanged">
                <ComboBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="{Binding Name}" Width="18"/><ItemsControl ItemsSource="{Binding Colors}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Width="10" Height="18" Background="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="Object palette" />
              <ComboBox x:Name="ObjectPaletteBox" Margin="0,3,0,10" SelectionChanged="HeaderSelectionChanged">
                <ComboBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="{Binding Name}" Width="18"/><ItemsControl ItemsSource="{Binding Colors}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Width="10" Height="18" Background="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></DataTemplate></ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="Music" />
              <ComboBox x:Name="MusicBox" Margin="0,3,0,10" SelectionChanged="HeaderSelectionChanged" />
              <TextBlock Text="Time setting" />
              <ComboBox x:Name="TimeBox" Margin="0,3,0,18" SelectionChanged="HeaderSelectionChanged" />

              <TextBlock Classes="section" Text="Space" />
              <TextBlock x:Name="SpaceText" Text="No area loaded" TextWrapping="Wrap" Margin="0,0,0,18" />

              <TextBlock Classes="section" Text="External emulator" />
              <TextBox x:Name="EmulatorPathBox" PlaceholderText="Emulator executable" Margin="0,0,0,6" />
              <Button Content="Choose emulator" Click="ChooseEmulator_Click" Margin="0,0,0,8" />
              <TextBlock Text="Arguments, one per line. Use {rom} for the temporary ROM." TextWrapping="Wrap" FontSize="12" />
              <TextBox x:Name="EmulatorArgumentsBox" AcceptsReturn="True" Height="86" Text="{}{rom}" Margin="0,5,0,0" />
            </StackPanel>
          </ScrollViewer>
        </Border>
      </SplitView.Pane>

      <Border Background="#0D141D">
        <Grid>
          <ScrollViewer x:Name="LevelScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <local:LevelCanvas x:Name="EditorCanvas" />
          </ScrollViewer>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,14" Spacing="6">
            <Button x:Name="SafetyBanner" IsVisible="False" Padding="13,7"
                    Background="#A92B1E" BorderBrush="#FFB4A8" BorderThickness="1"
                    Click="SafetyBanner_Click">
              <TextBlock x:Name="SafetyBannerText" FontWeight="SemiBold" Foreground="White" />
            </Button>
            <Button x:Name="FixUnsafeButton" IsVisible="False" Content="Fix ordering"
                    Padding="10,7" Background="#8A5A12" BorderBrush="#FFD36A" BorderThickness="1"
                    Click="FixUnsafe_Click">
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </SplitView>

    <Border Grid.Row="3" Background="#111B28" BorderBrush="#31445A" BorderThickness="0,1,0,0" Padding="10,6">
      <TextBlock x:Name="RomStatusText" Text="No ROM loaded" TextWrapping="Wrap" Foreground="#9FB0C4" />
    </Border>

    <Expander x:Name="DiagnosticsPanel" Grid.Row="4" Header="Diagnostics" IsExpanded="False" Background="#101720">
      <ListBox x:Name="DiagnosticsList" MaxWidth="900" HorizontalAlignment="Left">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" TextWrapping="Wrap" MaxWidth="860" Margin="3,2" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Expander>
  </Grid>
</Window>
